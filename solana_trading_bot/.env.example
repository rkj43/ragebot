# ---------------------------------------------------------------------------
# Solana trading bot configuration — copy to .env and fill in.
# NEVER commit the real .env. The trading wallet must hold LIMITED capital.
# ---------------------------------------------------------------------------

# Wallet secret key: base58 string or JSON byte array from solana-keygen.
# Required only for live mode. Never printed, never stored anywhere else.
PRIVATE_KEY=

# Solana RPC endpoint (a dedicated provider is strongly recommended for live).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# "paper" (default, simulated fills) or "live" (real swaps, tiny capital only).
TRADING_MODE=paper

# Optional safety check: refuse to run if the loaded wallet is not this one.
EXPECTED_WALLET_ADDRESS=

# Operational tuning (hard risk limits are in code and cannot be set here).
DATABASE_URL=sqlite:///solana_trading_bot.db
SLIPPAGE_BPS=50
POLL_INTERVAL_SECONDS=2
CANDLE_INTERVAL_SECONDS=60
PAPER_STARTING_USDC=1000
LOG_DIR=logs
